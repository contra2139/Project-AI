# CBX Trading Bot - Environment Variables Example
# Copy this file to .env and fill in the values

# --- ENVIRONMENT ---
ENV=development # production or development
DEBUG=true

# --- DATABASE ---
DB_USER=cbx_user
DB_PASSWORD=your_secure_password
DB_NAME=cbx_db
# URL format: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
DATABASE_URL=postgresql+asyncpg://cbx_user:your_secure_password@localhost:5432/cbx_db

# --- REDIS ---
# Use localhost for host run, or redis for docker
REDIS_URL=redis://localhost:6379

# --- SECURITY ---
# JWT Secret Key - MUST BE AT LEAST 32 CHARACTERS
SECRET_KEY=your_very_long_and_secure_secret_key_here_32_chars

# --- BINANCE API ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=your_telegram_user_id

# --- CORS ---
# Comma separated list of allowed origins. Required in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app-domain.com
